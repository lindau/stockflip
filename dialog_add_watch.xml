<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <EditText
        android:id="@+id/watchSymbol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Stock Symbol (e.g., AAPL)" />

    <Spinner
        android:id="@+id/criteriaTypeSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp" />

    <LinearLayout
        android:id="@+id/thresholdLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/thresholdValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Threshold Value"
            android:inputType="numberDecimal" />

        <RadioGroup
            android:id="@+id/comparisonRadioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioAbove"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Över"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioBelow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Under" />
        </RadioGroup>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/dropPercentageLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/dropPercentageValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Drop Percentage"
            android:inputType="numberDecimal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="%"
            android:textSize="16sp"
            android:gravity="center_vertical"
            android:paddingStart="8dp" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/notifyOnTrigger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notify when triggered"
        android:checked="true"
        android:layout_marginTop="8dp" />

</LinearLayout>
