<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StockFlip" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Surface colors -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorSurfaceVariant">@color/purple_200</item>
        <item name="colorOnSurfaceVariant">@color/black</item>
        <!-- Card colors -->
        <item name="materialCardViewStyle">@style/Widget.StockFlip.CardView</item>
        <!-- Text Appearance -->
        <item name="textAppearanceTitleMedium">@style/TextAppearance.StockFlip.TitleMedium</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.StockFlip.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.StockFlip.BodyMedium</item>
    </style>

    <style name="Widget.StockFlip.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="rippleColor">@color/purple_200</item>
    </style>

    <style name="TextAppearance.StockFlip.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TextAppearance.StockFlip.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TextAppearance.StockFlip.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/black</item>
    </style>
</resources> 